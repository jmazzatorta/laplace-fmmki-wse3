task tx_complete_s() void {
    tx_fifo_s_tail = (tx_fifo_s_tail + 1) & (cons.FIFO_DEPTH - 1);
    tx_fifo_s_count -= 1;
    tx_drain_s_busy = 0;
    if (tx_fifo_s_count > 0) @activate(cons.tx_drain_s_task_id);
}



// --- POINTERS ---
var ptr_bodies: [*]u32 = &bodies;
var ptr_forces_buf: [*]f32 = &forces_buf;
var ptr_fmm_done: [*]u32 = &fmm_done;

var ptr_m2m_offsets: [*]u16 = &m2m_offsets;
var ptr_m2m_child_indices: [*]u16 = &m2m_child_indices;
var ptr_m2m_v_indices: [*]u16 = &m2m_v_indices;
var ptr_m2m_sign_rr: [*]f32 = &m2m_sign_rr;
var ptr_m2m_sign_ri: [*]f32 = &m2m_sign_ri;
var ptr_m2m_sign_ir: [*]f32 = &m2m_sign_ir;
var ptr_m2m_sign_ii: [*]f32 = &m2m_sign_ii;

var ptr_m2l_offsets: [*]u16 = &m2l_offsets;
var ptr_m2l_source_indices: [*]u16 = &m2l_source_indices;
var ptr_m2l_v_indices: [*]u16 = &m2l_v_indices;
var ptr_m2l_sign_rr: [*]f32 = &m2l_sign_rr;
var ptr_m2l_sign_ri: [*]f32 = &m2l_sign_ri;
var ptr_m2l_sign_ir: [*]f32 = &m2l_sign_ir;
var ptr_m2l_sign_ii: [*]f32 = &m2l_sign_ii;

var ptr_l2l_offsets: [*]u16 = &l2l_offsets;
var ptr_l2l_source_indices: [*]u16 = &l2l_source_indices;
var ptr_l2l_v_indices: [*]u16 = &l2l_v_indices;
var ptr_l2l_sign_rr: [*]f32 = &l2l_sign_rr;
var ptr_l2l_sign_ri: [*]f32 = &l2l_sign_ri;
var ptr_l2l_sign_ir: [*]f32 = &l2l_sign_ir;
var ptr_l2l_sign_ii: [*]f32 = &l2l_sign_ii;

var ptr_m2l_agenda_lvl2: [*]u32 = &m2l_agenda_lvl2;
var ptr_m2l_agenda_lvl3: [*]u32 = &m2l_agenda_lvl3;
var ptr_m2l_agenda_lvl4: [*]u32 = &m2l_agenda_lvl4;
var ptr_num_targets_lvl2: [*]u32 = &num_targets_lvl2;
var ptr_num_targets_lvl3: [*]u32 = &num_targets_lvl3;
var ptr_num_targets_lvl4: [*]u32 = &num_targets_lvl4;
var ptr_expected_rx_lvl2: [*]u32 = &expected_rx_lvl2;
var ptr_expected_rx_lvl3: [*]u32 = &expected_rx_lvl3;
var ptr_expected_rx_lvl4: [*]u32 = &expected_rx_lvl4;

var ptr_p2p_agenda: [*]u32 = &p2p_agenda;
var ptr_num_p2p_neighbors: [*]u32 = &num_p2p_neighbors;


// --- COMPTIME ---
comptime {
    // Input queues
    @initialize_queue(cons.e_iq, .{ .color = c_e_in });
    @initialize_queue(cons.w_iq, .{ .color = c_w_in });
    @initialize_queue(cons.n_iq, .{ .color = c_n_in });
    @initialize_queue(cons.s_iq, .{ .color = c_s_in });

    // Output queues
    @initialize_queue(cons.e_oq, .{ .color = c_e_out }); 
    @initialize_queue(cons.w_oq, .{ .color = c_w_out }); 
    @initialize_queue(cons.n_oq, .{ .color = c_n_out }); 
    @initialize_queue(cons.s_oq, .{ .color = c_s_out }); 

    // Tasks binding
    @bind_local_task(rx_east, cons.task_rx_east_id);
    @bind_local_task(rx_west, cons.task_rx_west_id);
    @bind_local_task(rx_north, cons.task_rx_north_id);
    @bind_local_task(rx_south, cons.task_rx_south_id);

    @bind_local_task(m2l_send_task, cons.m2l_send_task_id);

    @bind_local_task(process_fifo, cons.process_fifo_task_id);

    @bind_local_task(tx_drain_e, cons.tx_drain_e_task_id);
    @bind_local_task(tx_drain_w, cons.tx_drain_w_task_id);
    @bind_local_task(tx_drain_n, cons.tx_drain_n_task_id);
    @bind_local_task(tx_drain_s, cons.tx_drain_s_task_id);

    @bind_local_task(tx_complete_e, cons.tx_complete_e_task_id);
    @bind_local_task(tx_complete_w, cons.tx_complete_w_task_id);
    @bind_local_task(tx_complete_n, cons.tx_complete_n_task_id);
    @bind_local_task(tx_complete_s, cons.tx_complete_s_task_id);

    @bind_local_task(tx_send_pld_e, cons.tx_send_pld_e_task_id);
    @bind_local_task(tx_send_pld_w, cons.tx_send_pld_w_task_id);
    @bind_local_task(tx_send_pld_n, cons.tx_send_pld_n_task_id);
    @bind_local_task(tx_send_pld_s, cons.tx_send_pld_s_task_id);

    // Symbol exports
    @export_symbol(ptr_bodies, "ptr_bodies");
    @export_symbol(ptr_forces_buf, "ptr_forces_buf");
    @export_symbol(ptr_fmm_done, "ptr_fmm_done");
    @export_symbol(start_fmm, "start_fmm");

    @export_symbol(ptr_canarino, "ptr_canarino");

    @export_symbol(ptr_m2m_offsets, "ptr_m2m_offsets");
    @export_symbol(ptr_m2m_child_indices, "ptr_m2m_child_indices");
    @export_symbol(ptr_m2m_v_indices, "ptr_m2m_v_indices");
    @export_symbol(ptr_m2m_sign_rr, "ptr_m2m_sign_rr");
    @export_symbol(ptr_m2m_sign_ri, "ptr_m2m_sign_ri");
    @export_symbol(ptr_m2m_sign_ir, "ptr_m2m_sign_ir");
    @export_symbol(ptr_m2m_sign_ii, "ptr_m2m_sign_ii");

    @export_symbol(ptr_m2l_offsets, "ptr_m2l_offsets");
    @export_symbol(ptr_m2l_source_indices, "ptr_m2l_source_indices");
    @export_symbol(ptr_m2l_v_indices, "ptr_m2l_v_indices");
    @export_symbol(ptr_m2l_sign_rr, "ptr_m2l_sign_rr");
    @export_symbol(ptr_m2l_sign_ri, "ptr_m2l_sign_ri");
    @export_symbol(ptr_m2l_sign_ir, "ptr_m2l_sign_ir");
    @export_symbol(ptr_m2l_sign_ii, "ptr_m2l_sign_ii");

    @export_symbol(ptr_l2l_offsets, "ptr_l2l_offsets");
    @export_symbol(ptr_l2l_source_indices, "ptr_l2l_source_indices");
    @export_symbol(ptr_l2l_v_indices, "ptr_l2l_v_indices");
    @export_symbol(ptr_l2l_sign_rr, "ptr_l2l_sign_rr");
    @export_symbol(ptr_l2l_sign_ri, "ptr_l2l_sign_ri");
    @export_symbol(ptr_l2l_sign_ir, "ptr_l2l_sign_ir");
    @export_symbol(ptr_l2l_sign_ii, "ptr_l2l_sign_ii");

    @export_symbol(ptr_m2l_agenda_lvl2, "ptr_m2l_agenda_lvl2");
    @export_symbol(ptr_m2l_agenda_lvl3, "ptr_m2l_agenda_lvl3");
    @export_symbol(ptr_m2l_agenda_lvl4, "ptr_m2l_agenda_lvl4");
    @export_symbol(ptr_num_targets_lvl2, "ptr_num_targets_lvl2");
    @export_symbol(ptr_num_targets_lvl3, "ptr_num_targets_lvl3");
    @export_symbol(ptr_num_targets_lvl4, "ptr_num_targets_lvl4");
    @export_symbol(ptr_expected_rx_lvl2, "ptr_expected_rx_lvl2");
    @export_symbol(ptr_expected_rx_lvl3, "ptr_expected_rx_lvl3");
    @export_symbol(ptr_expected_rx_lvl4, "ptr_expected_rx_lvl4");

    @export_symbol(ptr_p2p_agenda, "ptr_p2p_agenda");
    @export_symbol(ptr_num_p2p_neighbors, "ptr_num_p2p_neighbors");
}
