// --- FIFO CONSUMER ---
task process_fifo() void {
    if (rx_fifo_count > 0) {
        // 1. Legge il pacchetto più vecchio dalla coda RX
        const header = rx_fifo_headers[rx_fifo_tail];
        const msg_type = (header >> cons.SHIFT_MSG_TYPE) & cons.MASK_3BIT;
        const base_idx = rx_fifo_tail * cons.MAX_PAYLOAD;

        // 2. Ricopia i dati dalla FIFO nei buffer standard
        if (msg_type == @as(u32, cons.MSG_P2P)) {
            var src_dsd = @get_dsd(mem1d_dsd, .{ .tensor_access = |i|{cons.P2P_PAYLOAD_SIZE} -> rx_fifo_payloads[i] });
            src_dsd = @set_dsd_base_addr(src_dsd, @ptrcast([*]f32, &rx_fifo_payloads[base_idx]));
            const dest_dsd = @get_dsd(mem1d_dsd, .{ .tensor_access = |i|{cons.P2P_PAYLOAD_SIZE} -> p2p_rx_payload[i] });
            @fmovs(dest_dsd, src_dsd);
        } else {
            var src_dsd = @get_dsd(mem1d_dsd, .{ .tensor_access = |i|{cons.C_BUF_SIZE} -> rx_fifo_payloads[i] });
            src_dsd = @set_dsd_base_addr(src_dsd, @ptrcast([*]f32, &rx_fifo_payloads[base_idx]));
            const dest_dsd = @get_dsd(mem1d_dsd, .{ .tensor_access = |i|{cons.C_BUF_SIZE} -> rx_payload[i] });
            @fmovs(dest_dsd, src_dsd);
        }

        // 3. Chiama il tuo switchboard matematico
        process_packet_local(header);

        // 4. Libera lo slot (operazione a 1 ciclo di clock)
        rx_fifo_tail = (rx_fifo_tail + 1) & (cons.FIFO_DEPTH - 1);
        rx_fifo_count -= 1;

        // 5. Auto-riattivazione se ci sono ancora pacchetti
        if (rx_fifo_count > 0) {
            @activate(cons.process_fifo_task_id);
        }
    }
}


// --- ASYNC TX DRAINERS ---

// EAST
task tx_drain_e() void {
    if (tx_drain_e_busy == 1) return;
    if (tx_fifo_e_count == 0) return;
    
    tx_drain_e_busy = 1;
    const header = tx_fifo_e_headers[tx_fifo_e_tail];
    tx_header_buf_e[0] = header;
    const mem_tx_header_dsd = @get_dsd(mem1d_dsd, .{ .tensor_access = |i|{1} -> tx_header_buf_e[i] });
    
    // Step 1: Invia Header Async e incatena il Payload
    @fmovs(tx_hdr_e, mem_tx_header_dsd, .{ .async = true, .activate = cons.tx_send_pld_e_task_id }); 
}
task tx_send_pld_e() void {
    const header = tx_fifo_e_headers[tx_fifo_e_tail];
    const msg_type = (header >> cons.SHIFT_MSG_TYPE) & cons.MASK_3BIT;
    const base_idx = tx_fifo_e_tail * cons.MAX_PAYLOAD;

    // Step 2: Invia Payload Async e incatena il Complete
    if (msg_type == @as(u32, cons.MSG_P2P)) {
        var src_dsd = @get_dsd(mem1d_dsd, .{ .tensor_access = |i|{cons.P2P_PAYLOAD_SIZE} -> tx_fifo_e_payloads[i] });
        src_dsd = @set_dsd_base_addr(src_dsd, @ptrcast([*]f32, &tx_fifo_e_payloads[base_idx]));
        @fmovs(tx_p2p_payload_e, src_dsd, .{ .async = true, .activate = cons.tx_complete_e_task_id });
    } else {
        var src_dsd = @get_dsd(mem1d_dsd, .{ .tensor_access = |i|{cons.C_BUF_SIZE} -> tx_fifo_e_payloads[i] });
        src_dsd = @set_dsd_base_addr(src_dsd, @ptrcast([*]f32, &tx_fifo_e_payloads[base_idx]));
        @fmovs(tx_payload_e, src_dsd, .{ .async = true, .activate = cons.tx_complete_e_task_id });
    }
}
task tx_complete_e() void {
    // Step 3: Pulisci e riavvia se c'è coda
    tx_fifo_e_tail = (tx_fifo_e_tail + 1) & (cons.FIFO_DEPTH - 1);
    tx_fifo_e_count -= 1;
    tx_drain_e_busy = 0;
    if (tx_fifo_e_count > 0) @activate(cons.tx_drain_e_task_id);
}

