// pe.csl

const simprint = @import_module("<simprint>");

param memcpy_params : comptime_struct;
const sys_mod = @import_module("<memcpy/memcpy>", memcpy_params);

// --- GLOBAL PARAMETERS ---
param cells_per_side : u16;
param prob_range : f32;
param max_bodies_pe : u16;
param cell_size : f32;


// --- TOPOLOGY PARAMETERS ---
param parity_x : u16;
param parity_y : u16;


// --- COLORS ---
param color_e1 : color; 
param color_e2 : color; 
param color_e3 : color;
param color_e4 : color; 
param color_o1 : color; 
param color_o2 : color;
param color_o3 : color;
param color_o4 : color;


// --- RUNTIME VARIABLES ---
var pe_x: u16 = 0;
var pe_y: u16 = 0;
var morton_id: u32 = 0;
var center_x: f32 = 0.0;
var center_y: f32 = 0.0;
var center_z: f32 = 0.0;
var pe_min_level: u16 = 4;


// --- MODULES ---
const cons = @import_module("constants.csl", .{
    .cells_per_side = cells_per_side,
    .prob_range = prob_range,
    .max_bodies_pe = max_bodies_pe,
    .cell_size = cell_size,
    .color_e1 = color_e1, .color_e2 = color_e2, .color_e3 = color_e3, .color_e4 = color_e4,
    .color_o1 = color_o1, .color_o2 = color_o2, .color_o3 = color_o3, .color_o4 = color_o4
});
const geom = @import_module("geometry.csl", .{
    .prob_range = prob_range,
    .cells_per_side = cells_per_side,
    .TREE_H = cons.TREE_H
});
const kernels = @import_module("kernels.csl", .{ 
    .P = cons.P,
    .M2M_N_ENTRIES = cons.M2M_N_ENTRIES,
    .M2L_N_ENTRIES = cons.M2L_N_ENTRIES,
    .L2L_N_ENTRIES = cons.L2L_N_ENTRIES,
    .N_BUCKETS = cons.N_BUCKETS,
    .P2P_PAYLOAD_SIZE = cons.P2P_PAYLOAD_SIZE
});


// --- TABLES ---
export var m2m_offsets       = @zeros([cons.N_BUCKETS]u16);
export var m2m_child_indices = @zeros([cons.M2M_N_ENTRIES]u16);
export var m2m_v_indices     = @zeros([cons.M2M_N_ENTRIES]u16);
export var m2m_sign_rr       = @zeros([cons.M2M_N_ENTRIES]f32);
export var m2m_sign_ri       = @zeros([cons.M2M_N_ENTRIES]f32);
export var m2m_sign_ir       = @zeros([cons.M2M_N_ENTRIES]f32);
export var m2m_sign_ii       = @zeros([cons.M2M_N_ENTRIES]f32);

export var m2l_offsets        = @zeros([cons.N_BUCKETS]u16);
export var m2l_source_indices = @zeros([cons.M2L_N_ENTRIES]u16);
export var m2l_v_indices      = @zeros([cons.M2L_N_ENTRIES]u16);
export var m2l_sign_rr        = @zeros([cons.M2L_N_ENTRIES]f32);
export var m2l_sign_ri        = @zeros([cons.M2L_N_ENTRIES]f32);
export var m2l_sign_ir        = @zeros([cons.M2L_N_ENTRIES]f32);
export var m2l_sign_ii        = @zeros([cons.M2L_N_ENTRIES]f32);

export var l2l_offsets        = @zeros([cons.N_BUCKETS]u16);
export var l2l_source_indices = @zeros([cons.L2L_N_ENTRIES]u16);
export var l2l_v_indices      = @zeros([cons.L2L_N_ENTRIES]u16);
export var l2l_sign_rr        = @zeros([cons.L2L_N_ENTRIES]f32);
export var l2l_sign_ri        = @zeros([cons.L2L_N_ENTRIES]f32);
export var l2l_sign_ir        = @zeros([cons.L2L_N_ENTRIES]f32);
export var l2l_sign_ii        = @zeros([cons.L2L_N_ENTRIES]f32);

// --- AGENDAS & COUNTERS ---
export var m2l_agenda_lvl2 = @zeros([cons.MAX_AGENDA]u32);
export var m2l_agenda_lvl3 = @zeros([cons.MAX_AGENDA]u32);
export var m2l_agenda_lvl4 = @zeros([cons.MAX_AGENDA]u32);

export var num_targets_lvl2 = @zeros([1]u32);
export var num_targets_lvl3 = @zeros([1]u32);
export var num_targets_lvl4 = @zeros([1]u32);

var expected_rx_lvl2 = @zeros([1]u32);
var expected_rx_lvl3 = @zeros([1]u32);
var expected_rx_lvl4 = @zeros([1]u32);

export var p2p_agenda = @zeros([cons.MAX_P2P_NEIGHBORS]u32);
export var num_p2p_neighbors = @zeros([1]u32);

var expected_rx_p2p = @zeros([1]u32);

// --- MEMORY BUFFERS ---
export var bodies = @zeros([cons.b_buf_len]u32);
var v_buf = @zeros([cons.C_BUF_SIZE]f32);
var v_buf_m2l = @zeros([cons.C_BUF_M2L_SIZE]f32);

var m_coeff_buf_lvl1 = @zeros([cons.C_BUF_SIZE]f32);
var m_coeff_buf_lvl2 = @zeros([cons.C_BUF_SIZE]f32);
var m_coeff_buf_lvl3 = @zeros([cons.C_BUF_SIZE]f32);

var l_coeff_buf_lvl2 = @zeros([cons.C_BUF_SIZE]f32);
var l_coeff_buf_lvl3 = @zeros([cons.C_BUF_SIZE]f32);
var l_coeff_buf_lvl4 = @zeros([cons.C_BUF_SIZE]f32);

var g_coeff_buf = @zeros([cons.C_BUF_SIZE]f32);

var contrib_buf = @zeros([cons.C_BUF_SIZE]f32);

// Universal Receive Buffer
var rx_payload = @zeros([cons.C_BUF_SIZE]f32);

var p2p_tx_payload = @zeros([cons.P2P_PAYLOAD_SIZE]f32);
var p2p_rx_payload = @zeros([cons.P2P_PAYLOAD_SIZE]f32);

// M2M globals
var m2m_rx_counts = [4]u16{0, 0, 0, 0}; 

// M2L globals
var current_m2l_level: u16 = 2; 
var send_indices = [3]u16{0, 0, 0};
var m2l_tx_done: u16 = 0;
var m2l_phase_done: u16 = 0;

// L2L globals
var l2l_msg_pending: u16 = 0;
var l2l_pending_extra: u32 = 0;
var l2l_pending_payload = @zeros([cons.C_BUF_SIZE]f32);

// L2P globals
var l2p_done: u16 = 0;

// P2P globals
var p2p_send_index: u16 = 0;
var p2p_send_done: u16 = 0;

fn get_num_entries(lvl_idx: u16) u32 {
    if (lvl_idx == 0) return num_targets_lvl2[0];
    if (lvl_idx == 1) return num_targets_lvl3[0];
    return num_targets_lvl4[0];
}

fn get_target_info(lvl_idx: u16, index: u16) u32 {
    if (lvl_idx == 0) return m2l_agenda_lvl2[index];
    if (lvl_idx == 1) return m2l_agenda_lvl3[index];
    return m2l_agenda_lvl4[index];
}


// --- FIFO BUFFERS ---
var rx_fifo_headers = @zeros([cons.FIFO_DEPTH]u32);
var rx_fifo_payloads = @zeros([cons.FIFO_DEPTH * cons.MAX_PAYLOAD]f32);
var rx_fifo_head: u16 = 0;
var rx_fifo_tail: u16 = 0;
var rx_fifo_count: u16 = 0;

var tx_fifo_e_headers = @zeros([cons.FIFO_DEPTH]u32);
var tx_fifo_e_payloads = @zeros([cons.FIFO_DEPTH * cons.MAX_PAYLOAD]f32);
var tx_fifo_e_head: u16 = 0;
var tx_fifo_e_tail: u16 = 0;
var tx_fifo_e_count: u16 = 0;

var tx_fifo_w_headers = @zeros([cons.FIFO_DEPTH]u32);
var tx_fifo_w_payloads = @zeros([cons.FIFO_DEPTH * cons.MAX_PAYLOAD]f32);
var tx_fifo_w_head: u16 = 0;
var tx_fifo_w_tail: u16 = 0;
var tx_fifo_w_count: u16 = 0;

var tx_fifo_n_headers = @zeros([cons.FIFO_DEPTH]u32);
var tx_fifo_n_payloads = @zeros([cons.FIFO_DEPTH * cons.MAX_PAYLOAD]f32);
var tx_fifo_n_head: u16 = 0;
var tx_fifo_n_tail: u16 = 0;
var tx_fifo_n_count: u16 = 0;

var tx_fifo_s_headers = @zeros([cons.FIFO_DEPTH]u32);
var tx_fifo_s_payloads = @zeros([cons.FIFO_DEPTH * cons.MAX_PAYLOAD]f32);
var tx_fifo_s_head: u16 = 0;
var tx_fifo_s_tail: u16 = 0;
var tx_fifo_s_count: u16 = 0;

// --- ASYNC DRAINER FLAGS ---
var tx_drain_e_busy: u16 = 0;
var tx_drain_w_busy: u16 = 0;
var tx_drain_n_busy: u16 = 0;
var tx_drain_s_busy: u16 = 0;

// --- RESULTS BUFFERS ---
export var forces_buf = @zeros([cons.max_bodies_pe * 4]f32);
export var fmm_done = @zeros([1]u32);


// --- NETWORK DSDs ---
var tx_header_buf_e = @zeros([1]u32);
var tx_header_buf_w = @zeros([1]u32);
var tx_header_buf_n = @zeros([1]u32);
var tx_header_buf_s = @zeros([1]u32);

var rx_hdr_e = @zeros([1]u32); var rx_hdr_w = @zeros([1]u32);
var rx_hdr_n = @zeros([1]u32); var rx_hdr_s = @zeros([1]u32);

const c_e_out = if (parity_x == 0) cons.color_e1 else cons.color_o1;
const c_w_out = if (parity_x == 0) cons.color_e3 else cons.color_o3;
const c_n_out = if (parity_y == 0) cons.color_e2 else cons.color_o2;
const c_s_out = if (parity_y == 0) cons.color_e4 else cons.color_o4;

const c_e_in  = if (parity_x == 0) cons.color_o3 else cons.color_e3;
const c_w_in  = if (parity_x == 0) cons.color_o1 else cons.color_e1;
const c_n_in  = if (parity_y == 0) cons.color_o4 else cons.color_e4;
const c_s_in  = if (parity_y == 0) cons.color_o2 else cons.color_e2;

const tx_hdr_e = @get_dsd(fabout_dsd, .{ .fabric_color = c_e_out, .extent = 1, .output_queue = cons.e_oq });
const tx_hdr_w = @get_dsd(fabout_dsd, .{ .fabric_color = c_w_out, .extent = 1, .output_queue = cons.w_oq });
const tx_hdr_n = @get_dsd(fabout_dsd, .{ .fabric_color = c_n_out, .extent = 1, .output_queue = cons.n_oq });
const tx_hdr_s = @get_dsd(fabout_dsd, .{ .fabric_color = c_s_out, .extent = 1, .output_queue = cons.s_oq });

const tx_payload_e = @get_dsd(fabout_dsd, .{ .fabric_color = c_e_out, .extent = cons.C_BUF_SIZE, .output_queue = cons.e_oq });
const tx_payload_w = @get_dsd(fabout_dsd, .{ .fabric_color = c_w_out, .extent = cons.C_BUF_SIZE, .output_queue = cons.w_oq });
const tx_payload_n = @get_dsd(fabout_dsd, .{ .fabric_color = c_n_out, .extent = cons.C_BUF_SIZE, .output_queue = cons.n_oq });
const tx_payload_s = @get_dsd(fabout_dsd, .{ .fabric_color = c_s_out, .extent = cons.C_BUF_SIZE, .output_queue = cons.s_oq });

const rx_fabin_hdr_e = @get_dsd(fabin_dsd, .{ .fabric_color = c_e_in, .extent = 1, .input_queue = cons.e_iq });
const rx_fabin_hdr_w = @get_dsd(fabin_dsd, .{ .fabric_color = c_w_in, .extent = 1, .input_queue = cons.w_iq });
const rx_fabin_hdr_n = @get_dsd(fabin_dsd, .{ .fabric_color = c_n_in, .extent = 1, .input_queue = cons.n_iq });
const rx_fabin_hdr_s = @get_dsd(fabin_dsd, .{ .fabric_color = c_s_in, .extent = 1, .input_queue = cons.s_iq });

const rx_fabin_payload_e = @get_dsd(fabin_dsd, .{ .fabric_color = c_e_in, .extent = cons.C_BUF_SIZE, .input_queue = cons.e_iq });
const rx_fabin_payload_w = @get_dsd(fabin_dsd, .{ .fabric_color = c_w_in, .extent = cons.C_BUF_SIZE, .input_queue = cons.w_iq });
const rx_fabin_payload_n = @get_dsd(fabin_dsd, .{ .fabric_color = c_n_in, .extent = cons.C_BUF_SIZE, .input_queue = cons.n_iq });
const rx_fabin_payload_s = @get_dsd(fabin_dsd, .{ .fabric_color = c_s_in, .extent = cons.C_BUF_SIZE, .input_queue = cons.s_iq });

const tx_p2p_payload_e = @get_dsd(fabout_dsd, .{ .fabric_color = c_e_out, .extent = cons.P2P_PAYLOAD_SIZE, .output_queue = cons.e_oq });
const tx_p2p_payload_w = @get_dsd(fabout_dsd, .{ .fabric_color = c_w_out, .extent = cons.P2P_PAYLOAD_SIZE, .output_queue = cons.w_oq });
const tx_p2p_payload_n = @get_dsd(fabout_dsd, .{ .fabric_color = c_n_out, .extent = cons.P2P_PAYLOAD_SIZE, .output_queue = cons.n_oq });
const tx_p2p_payload_s = @get_dsd(fabout_dsd, .{ .fabric_color = c_s_out, .extent = cons.P2P_PAYLOAD_SIZE, .output_queue = cons.s_oq });

const rx_p2p_payload_e = @get_dsd(fabin_dsd, .{ .fabric_color = c_e_in, .extent = cons.P2P_PAYLOAD_SIZE, .input_queue = cons.e_iq });
const rx_p2p_payload_w = @get_dsd(fabin_dsd, .{ .fabric_color = c_w_in, .extent = cons.P2P_PAYLOAD_SIZE, .input_queue = cons.w_iq });
const rx_p2p_payload_n = @get_dsd(fabin_dsd, .{ .fabric_color = c_n_in, .extent = cons.P2P_PAYLOAD_SIZE, .input_queue = cons.n_iq });
const rx_p2p_payload_s = @get_dsd(fabin_dsd, .{ .fabric_color = c_s_in, .extent = cons.P2P_PAYLOAD_SIZE, .input_queue = cons.s_iq });


// --- TRIGGER (P2M -> M2M) ---
fn compute_p2m() void {
    for (@range(u16, cons.C_BUF_SIZE)) |i| {
        g_coeff_buf[i] = 0.0;
    }

    const count : u16 = @as(u16, bodies[1]);

    // TODO If count == 0, skip

    const bodies_offset : u16 = 2;

    for (@range(u16, count)) |b| {
        var i_b : u16 = bodies_offset + b * 4;

        var dx : f32 = @bitcast(f32, bodies[i_b])     - center_x;
        var dy : f32 = @bitcast(f32, bodies[i_b + 1]) - center_y;
        var dz : f32 = @bitcast(f32, bodies[i_b + 2]) - center_z;
        var q  : f32 = @bitcast(f32, bodies[i_b + 3]);

        kernels.compute_solid_harmonics(dx, dy, dz, &contrib_buf);

        const g_coeff_dsd = @get_dsd(mem1d_dsd, .{ .tensor_access = |i|{cons.C_BUF_SIZE} -> g_coeff_buf[i] });
        const contrib_dsd = @get_dsd(mem1d_dsd, .{ .tensor_access = |i|{cons.C_BUF_SIZE} -> contrib_buf[i] });
        @fmacs(g_coeff_dsd, g_coeff_dsd, contrib_dsd, q);
    }
}

// --- CANARY TEST ---
export var canarino = @zeros([1]u32);
export var ptr_canarino : [*]u32 = &canarino;
export fn canary_start_fmm() void {
    canarino[0] = 42;
    sys_mod.unblock_cmd_stream();
}


// --- ENTRY FUNCTION ---
export fn start_fmm() void {

    simprint.fmt("({d},{d})STARTFMM.Min:{d}", .{pe_x, pe_y, pe_min_level});

    morton_id = bodies[0];

    pe_x = 0; pe_y = 0;
    geom.morton_decode(morton_id, &pe_x, &pe_y);

    var cell_x: u16 = 0; var cell_y: u16 = 0; var cell_z: u16 = 0;
    for (@range(u16, cons.TREE_H)) |i| {
        cell_x |= @as(u16, (morton_id >> (3 * i)) & 1) << i;
        cell_y |= @as(u16, (morton_id >> (3 * i + 1)) & 1) << i;
        cell_z |= @as(u16, (morton_id >> (3 * i + 2)) & 1) << i;
    }
    center_x = (@as(f32, cell_x) + 0.5) * cons.cell_size;
    center_y = (@as(f32, cell_y) + 0.5) * cons.cell_size;
    center_z = (@as(f32, cell_z) + 0.5) * cons.cell_size;

    pe_min_level = geom.get_pe_min_level(morton_id);

    if (pe_min_level < 2) {
        pe_min_level = 2;
    }

    // TODO nella versione con più cicli pulire tutti i buffer qui
    for (@range(u16, cons.max_bodies_pe * 4)) |i| {
        forces_buf[i] = 0.0;
    }

    expected_rx_p2p[0] = num_p2p_neighbors[0];  
    
    const mem_rx_hdr_e = @get_dsd(mem1d_dsd, .{ .tensor_access = |i|{1} -> rx_hdr_e[i] });
    @fmovs(mem_rx_hdr_e, rx_fabin_hdr_e, .{ .async = true, .activate = cons.task_rx_east_id });
    const mem_rx_hdr_w = @get_dsd(mem1d_dsd, .{ .tensor_access = |i|{1} -> rx_hdr_w[i] });
    @fmovs(mem_rx_hdr_w, rx_fabin_hdr_w, .{ .async = true, .activate = cons.task_rx_west_id });
    const mem_rx_hdr_n = @get_dsd(mem1d_dsd, .{ .tensor_access = |i|{1} -> rx_hdr_n[i] });
    @fmovs(mem_rx_hdr_n, rx_fabin_hdr_n, .{ .async = true, .activate = cons.task_rx_north_id });
    const mem_rx_hdr_s = @get_dsd(mem1d_dsd, .{ .tensor_access = |i|{1} -> rx_hdr_s[i] });
    @fmovs(mem_rx_hdr_s, rx_fabin_hdr_s, .{ .async = true, .activate = cons.task_rx_south_id });

    compute_p2m();

    simprint.fmt("({d},{d})PreSendM2M", .{pe_x, pe_y});

    const parent_morton = geom.get_parent_morton(morton_id, 4);
    var tgt_x: u16 = 0; var tgt_y: u16 = 0;
    geom.morton_decode(parent_morton, &tgt_x, &tgt_y);

    const my_child_id = geom.get_level_id(morton_id, 4);
    const extra_data = (@as(u32, 4) << 8) | my_child_id;

    // Stagger sender by pe_x to avoid initial burst
    const stagger_cycles: u16 = pe_x * 64;
    var counter: u16 = 0;
    while (counter < stagger_cycles) {
        counter += 1;
    }

    const g_coeff_dsd = @get_dsd(mem1d_dsd, .{ .tensor_access = |i|{cons.C_BUF_SIZE} -> g_coeff_buf[i] });
    send_packet(tgt_x, tgt_y, cons.MSG_M2M, extra_data, g_coeff_dsd);

    simprint.fmt("({d},{d})PostSendM2M", .{pe_x, pe_y});

    if (pe_min_level == cons.TREE_H) {
        start_m2l_phase();
    }

}


// --- UNIVERSAL OUT ROUTER ---
fn send_packet(tgt_x: u16, tgt_y: u16, msg_type: u32, extra_data: u32, payload_dsd: mem1d_dsd) void {
    
    const header = (@as(u32, tgt_x) << cons.SHIFT_TGT_X) |
                   (@as(u32, tgt_y) << cons.SHIFT_TGT_Y) |
                   (msg_type << cons.SHIFT_MSG_TYPE) |
                   extra_data;

    if (tgt_x != pe_x) {
        if (tgt_x > pe_x) {
            // --- EAST ---
            simprint.fmt("({d},{d})SP-E-T{d}", .{pe_x, pe_y, msg_type});
            if (tx_fifo_e_count >= cons.FIFO_DEPTH) { simprint.fmt("({d},{d})TX_FIFO_E FULL", .{pe_x, pe_y}); }
            tx_fifo_e_headers[tx_fifo_e_head] = header;
            const base_idx = tx_fifo_e_head * cons.MAX_PAYLOAD;
            
            var dest_dsd = @get_dsd(mem1d_dsd, .{ .tensor_access = |i|{cons.C_BUF_SIZE} -> tx_fifo_e_payloads[i] });
            if (msg_type == @as(u32, cons.MSG_P2P)) {
                dest_dsd = @get_dsd(mem1d_dsd, .{ .tensor_access = |i|{cons.P2P_PAYLOAD_SIZE} -> tx_fifo_e_payloads[i] });
            }
            dest_dsd = @set_dsd_base_addr(dest_dsd, @ptrcast([*]f32, &tx_fifo_e_payloads[base_idx]));
            @fmovs(dest_dsd, payload_dsd);
            
            tx_fifo_e_head = (tx_fifo_e_head + 1) & (cons.FIFO_DEPTH - 1);
            tx_fifo_e_count += 1;
            @activate(cons.tx_drain_e_task_id);
            
        } else {
            // --- WEST ---
            simprint.fmt("({d},{d})SP-W-T{d}", .{pe_x, pe_y, msg_type});
            if (tx_fifo_w_count >= cons.FIFO_DEPTH) { simprint.fmt("({d},{d})TX_FIFO_W FULL", .{pe_x, pe_y}); }
            tx_fifo_w_headers[tx_fifo_w_head] = header;
            const base_idx = tx_fifo_w_head * cons.MAX_PAYLOAD;
            
            var dest_dsd = @get_dsd(mem1d_dsd, .{ .tensor_access = |i|{cons.C_BUF_SIZE} -> tx_fifo_w_payloads[i] });
            if (msg_type == @as(u32, cons.MSG_P2P)) {
                dest_dsd = @get_dsd(mem1d_dsd, .{ .tensor_access = |i|{cons.P2P_PAYLOAD_SIZE} -> tx_fifo_w_payloads[i] });
            }
            dest_dsd = @set_dsd_base_addr(dest_dsd, @ptrcast([*]f32, &tx_fifo_w_payloads[base_idx]));
            @fmovs(dest_dsd, payload_dsd);
            
            tx_fifo_w_head = (tx_fifo_w_head + 1) & (cons.FIFO_DEPTH - 1);
            tx_fifo_w_count += 1;
            @activate(cons.tx_drain_w_task_id);
        }
    } else if (tgt_y != pe_y) {
        if (tgt_y > pe_y) {
            // --- SOUTH ---
            simprint.fmt("({d},{d})SP-S-T{d}", .{pe_x, pe_y, msg_type});
            if (tx_fifo_s_count >= cons.FIFO_DEPTH) { simprint.fmt("({d},{d})TX_FIFO_S FULL", .{pe_x, pe_y}); }
            tx_fifo_s_headers[tx_fifo_s_head] = header;
            const base_idx = tx_fifo_s_head * cons.MAX_PAYLOAD;
            
            var dest_dsd = @get_dsd(mem1d_dsd, .{ .tensor_access = |i|{cons.C_BUF_SIZE} -> tx_fifo_s_payloads[i] });
            if (msg_type == @as(u32, cons.MSG_P2P)) {
                dest_dsd = @get_dsd(mem1d_dsd, .{ .tensor_access = |i|{cons.P2P_PAYLOAD_SIZE} -> tx_fifo_s_payloads[i] });
            }
            dest_dsd = @set_dsd_base_addr(dest_dsd, @ptrcast([*]f32, &tx_fifo_s_payloads[base_idx]));
            @fmovs(dest_dsd, payload_dsd);
            
            tx_fifo_s_head = (tx_fifo_s_head + 1) & (cons.FIFO_DEPTH - 1);
            tx_fifo_s_count += 1;
            @activate(cons.tx_drain_s_task_id);
            
        } else {
            // --- NORTH ---
            simprint.fmt("({d},{d})SP-N-T{d}", .{pe_x, pe_y, msg_type});
            if (tx_fifo_n_count >= cons.FIFO_DEPTH) { simprint.fmt("({d},{d})TX_FIFO_N FULL", .{pe_x, pe_y}); }
            tx_fifo_n_headers[tx_fifo_n_head] = header;
            const base_idx = tx_fifo_n_head * cons.MAX_PAYLOAD;
            
            var dest_dsd = @get_dsd(mem1d_dsd, .{ .tensor_access = |i|{cons.C_BUF_SIZE} -> tx_fifo_n_payloads[i] });
            if (msg_type == @as(u32, cons.MSG_P2P)) {
                dest_dsd = @get_dsd(mem1d_dsd, .{ .tensor_access = |i|{cons.P2P_PAYLOAD_SIZE} -> tx_fifo_n_payloads[i] });
            }
            dest_dsd = @set_dsd_base_addr(dest_dsd, @ptrcast([*]f32, &tx_fifo_n_payloads[base_idx]));
            @fmovs(dest_dsd, payload_dsd);
            
            tx_fifo_n_head = (tx_fifo_n_head + 1) & (cons.FIFO_DEPTH - 1);
            tx_fifo_n_count += 1;
            @activate(cons.tx_drain_n_task_id);
        }
    } else {
        // --- SELF ---
        simprint.fmt("({d},{d})SR-DIR", .{pe_x, pe_y});
        if (rx_fifo_count >= cons.FIFO_DEPTH) { simprint.fmt("({d},{d})RX_FIFO FULL", .{pe_x, pe_y}); }
        rx_fifo_headers[rx_fifo_head] = header;
        const base_idx = rx_fifo_head * cons.MAX_PAYLOAD;

        var dest_dsd = @get_dsd(mem1d_dsd, .{ .tensor_access = |i|{cons.C_BUF_SIZE} -> rx_fifo_payloads[i] });
        if (msg_type == @as(u32, cons.MSG_P2P)) {
            dest_dsd = @get_dsd(mem1d_dsd, .{ .tensor_access = |i|{cons.P2P_PAYLOAD_SIZE} -> rx_fifo_payloads[i] });
        }
        dest_dsd = @set_dsd_base_addr(dest_dsd, @ptrcast([*]f32, &rx_fifo_payloads[base_idx]));
        @fmovs(dest_dsd, payload_dsd);

        rx_fifo_head = (rx_fifo_head + 1) & (cons.FIFO_DEPTH - 1);
        rx_fifo_count += 1;
        @activate(cons.process_fifo_task_id);
    }
}

// --- FORWARD ROUTER ---
fn forward_packet(header: u32, in_payload_default: fabin_dsd, in_payload_p2p: fabin_dsd) void {
    const tgt_x = (header >> cons.SHIFT_TGT_X) & cons.MASK_9BIT;
    const tgt_y = (header >> cons.SHIFT_TGT_Y) & cons.MASK_9BIT;
    const msg_type = (header >> cons.SHIFT_MSG_TYPE) & cons.MASK_3BIT;
    
    if (tgt_x != @as(u32, pe_x)) {
        if (tgt_x > @as(u32, pe_x)) {
            // --- EAST ---
            if (tx_fifo_e_count >= cons.FIFO_DEPTH) { simprint.fmt("({d},{d})TX_FIFO_E FULL(FWD)", .{pe_x, pe_y}); }
            tx_fifo_e_headers[tx_fifo_e_head] = header;
            const base_idx = tx_fifo_e_head * cons.MAX_PAYLOAD;
            if (msg_type == @as(u32, cons.MSG_P2P)) {
                var dest_dsd = @get_dsd(mem1d_dsd, .{ .tensor_access = |i|{cons.P2P_PAYLOAD_SIZE} -> tx_fifo_e_payloads[i] });
                dest_dsd = @set_dsd_base_addr(dest_dsd, @ptrcast([*]f32, &tx_fifo_e_payloads[base_idx]));
                @fmovs(dest_dsd, in_payload_p2p);
            } else {
                var dest_dsd = @get_dsd(mem1d_dsd, .{ .tensor_access = |i|{cons.C_BUF_SIZE} -> tx_fifo_e_payloads[i] });
                dest_dsd = @set_dsd_base_addr(dest_dsd, @ptrcast([*]f32, &tx_fifo_e_payloads[base_idx]));
                @fmovs(dest_dsd, in_payload_default);
            }
            tx_fifo_e_head = (tx_fifo_e_head + 1) & (cons.FIFO_DEPTH - 1);
            tx_fifo_e_count += 1;
            @activate(cons.tx_drain_e_task_id);
        } else {
            // --- WEST ---
            if (tx_fifo_w_count >= cons.FIFO_DEPTH) { simprint.fmt("({d},{d})TX_FIFO_W FULL(FWD)", .{pe_x, pe_y}); }
            tx_fifo_w_headers[tx_fifo_w_head] = header;
            const base_idx = tx_fifo_w_head * cons.MAX_PAYLOAD;
            if (msg_type == @as(u32, cons.MSG_P2P)) {
                var dest_dsd = @get_dsd(mem1d_dsd, .{ .tensor_access = |i|{cons.P2P_PAYLOAD_SIZE} -> tx_fifo_w_payloads[i] });
                dest_dsd = @set_dsd_base_addr(dest_dsd, @ptrcast([*]f32, &tx_fifo_w_payloads[base_idx]));
                @fmovs(dest_dsd, in_payload_p2p);
            } else {
                var dest_dsd = @get_dsd(mem1d_dsd, .{ .tensor_access = |i|{cons.C_BUF_SIZE} -> tx_fifo_w_payloads[i] });
                dest_dsd = @set_dsd_base_addr(dest_dsd, @ptrcast([*]f32, &tx_fifo_w_payloads[base_idx]));
                @fmovs(dest_dsd, in_payload_default);
            }
            tx_fifo_w_head = (tx_fifo_w_head + 1) & (cons.FIFO_DEPTH - 1);
            tx_fifo_w_count += 1;
            @activate(cons.tx_drain_w_task_id);
        }
    } else if (tgt_y != @as(u32, pe_y)) {
        if (tgt_y > @as(u32, pe_y)) {
            // --- SOUTH ---
            if (tx_fifo_s_count >= cons.FIFO_DEPTH) { simprint.fmt("({d},{d})TX_FIFO_S FULL(FWD)", .{pe_x, pe_y}); }
            tx_fifo_s_headers[tx_fifo_s_head] = header;
            const base_idx = tx_fifo_s_head * cons.MAX_PAYLOAD;
            if (msg_type == @as(u32, cons.MSG_P2P)) {
                var dest_dsd = @get_dsd(mem1d_dsd, .{ .tensor_access = |i|{cons.P2P_PAYLOAD_SIZE} -> tx_fifo_s_payloads[i] });
                dest_dsd = @set_dsd_base_addr(dest_dsd, @ptrcast([*]f32, &tx_fifo_s_payloads[base_idx]));
                @fmovs(dest_dsd, in_payload_p2p);
            } else {
                var dest_dsd = @get_dsd(mem1d_dsd, .{ .tensor_access = |i|{cons.C_BUF_SIZE} -> tx_fifo_s_payloads[i] });
                dest_dsd = @set_dsd_base_addr(dest_dsd, @ptrcast([*]f32, &tx_fifo_s_payloads[base_idx]));
                @fmovs(dest_dsd, in_payload_default);
            }
            tx_fifo_s_head = (tx_fifo_s_head + 1) & (cons.FIFO_DEPTH - 1);
            tx_fifo_s_count += 1;
            @activate(cons.tx_drain_s_task_id);
        } else {
            // --- NORTH ---
            if (tx_fifo_n_count >= cons.FIFO_DEPTH) { simprint.fmt("({d},{d})TX_FIFO_N FULL(FWD)", .{pe_x, pe_y}); }
            tx_fifo_n_headers[tx_fifo_n_head] = header;
            const base_idx = tx_fifo_n_head * cons.MAX_PAYLOAD;
            if (msg_type == @as(u32, cons.MSG_P2P)) {
                var dest_dsd = @get_dsd(mem1d_dsd, .{ .tensor_access = |i|{cons.P2P_PAYLOAD_SIZE} -> tx_fifo_n_payloads[i] });
                dest_dsd = @set_dsd_base_addr(dest_dsd, @ptrcast([*]f32, &tx_fifo_n_payloads[base_idx]));
                @fmovs(dest_dsd, in_payload_p2p);
            } else {
                var dest_dsd = @get_dsd(mem1d_dsd, .{ .tensor_access = |i|{cons.C_BUF_SIZE} -> tx_fifo_n_payloads[i] });
                dest_dsd = @set_dsd_base_addr(dest_dsd, @ptrcast([*]f32, &tx_fifo_n_payloads[base_idx]));
                @fmovs(dest_dsd, in_payload_default);
            }
            tx_fifo_n_head = (tx_fifo_n_head + 1) & (cons.FIFO_DEPTH - 1);
            tx_fifo_n_count += 1;
            @activate(cons.tx_drain_n_task_id);
        }
    }
}


// --- CENTRAL SWITCHBOARD ---
fn process_packet_local(header: u32) void {
    const msg_type = (header >> cons.SHIFT_MSG_TYPE) & cons.MASK_3BIT;
    const extra_data = header & cons.MASK_11BIT;

    if (msg_type == @as(u32, cons.MSG_M2M)) {
        process_m2m_local(extra_data);
    } else if (msg_type == @as(u32, cons.MSG_M2L)) {
        process_m2l_local(extra_data);
    } else if (msg_type == @as(u32, cons.MSG_L2L)) {
        process_l2l_local(extra_data);
    } else if (msg_type == @as(u32, cons.MSG_P2P)) {
        process_p2p_local(extra_data);
    }
}


// --- MATH KERNELS PROCESSORS ---
fn process_m2m_local(extra_data: u32) void {
    
    const child_level: u16 = @as(u16, extra_data >> 8);
    const child_idx: u32  = extra_data & 0xFF;

    const my_level = child_level - 1;
    const lvl_idx = my_level - 1;

    simprint.fmt("({d},{d})RxM2M cl:{d} ml:{d} cnt:{d}", .{pe_x, pe_y, child_level, my_level, m2m_rx_counts[lvl_idx]});

    if (my_level < 2) {
        return;
    }

    var my_coeff_ptr: *[cons.C_BUF_SIZE]f32 = &m_coeff_buf_lvl3;
    
    if (my_level == 2) { my_coeff_ptr = &m_coeff_buf_lvl2; }
    else if (my_level == 3) { my_coeff_ptr = &m_coeff_buf_lvl3; }
    else { return; } 

    var t_vec = @zeros([3]f32);
    if (child_level == 3) { geom.get_translation_vector(child_idx, 3, &t_vec); }
    else if (child_level == 4) { geom.get_translation_vector(child_idx, 4, &t_vec); }
    else { return; }
    
    kernels.compute_solid_harmonics(t_vec[0], t_vec[1], t_vec[2], &v_buf);

    kernels.m2m_translate(
        &v_buf, &rx_payload, my_coeff_ptr,
        &m2m_offsets, &m2m_child_indices, &m2m_v_indices,
        &m2m_sign_rr, &m2m_sign_ri, &m2m_sign_ir, &m2m_sign_ii
    );

    m2m_rx_counts[lvl_idx] += 1;

    if (m2m_rx_counts[lvl_idx] == 8) {
        
        simprint.fmt("PE ({d},{d}) M2M 8/8 Lvl:{d} Min:{d}\n", .{pe_x, pe_y, my_level, pe_min_level});

        if (my_level > 2) {
            const parent_morton = geom.get_parent_morton(morton_id, my_level);
            var tgt_x: u16 = 0; var tgt_y: u16 = 0;
            geom.morton_decode(parent_morton, &tgt_x, &tgt_y);

            const my_child_id = geom.get_level_id(morton_id, my_level);
            const new_extra_data = (@as(u32, my_level) << 8) | my_child_id;

            if (my_level == 3) { 
                const m_coeff_dsd_lvl3 = @get_dsd(mem1d_dsd, .{ .tensor_access = |i|{cons.C_BUF_SIZE} -> m_coeff_buf_lvl3[i] });
                send_packet(tgt_x, tgt_y, cons.MSG_M2M, new_extra_data, m_coeff_dsd_lvl3); 
            }
        }

        if (my_level == pe_min_level) {
            start_m2l_phase();
        }
    }
}


fn process_m2l_local(extra_data: u32) void {
    const level = @as(u16, (extra_data >> 9)) + 2;
    const tag = @as(u16, extra_data & 0x1FF);

    simprint.fmt("({d},{d})RxM2L L:{d} rem2:{d} rem3:{d} rem4:{d}", .{pe_x, pe_y, level, expected_rx_lvl2[0], expected_rx_lvl3[0], expected_rx_lvl4[0]});

    var l_coeff_ptr: *[cons.C_BUF_SIZE]f32 = &l_coeff_buf_lvl4;
    if (level == 2) { 
        l_coeff_ptr = &l_coeff_buf_lvl2; 
        if (expected_rx_lvl2[0] > 0) expected_rx_lvl2[0] -= 1; 
    }
    else if (level == 3) { 
        l_coeff_ptr = &l_coeff_buf_lvl3; 
        if (expected_rx_lvl3[0] > 0) expected_rx_lvl3[0] -= 1; 
    }
    else if (level == 4) { 
        l_coeff_ptr = &l_coeff_buf_lvl4; 
        if (expected_rx_lvl4[0] > 0) expected_rx_lvl4[0] -= 1; 
    }
    else return;

    const tag_i16 = @as(i16, tag);
    const dx_idx: i16 = (tag_i16 % 7) - 3;
    const dy_idx: i16 = ((tag_i16 / 7) % 7) - 3;
    const dz_idx: i16 = (tag_i16 / 49) - 3;
    
    const b_size: f32 = cons.box_size_at_level[level];
    const dist_x: f32 = @as(f32, dx_idx) * b_size;
    const dist_y: f32 = @as(f32, dy_idx) * b_size;
    const dist_z: f32 = @as(f32, dz_idx) * b_size;

    kernels.compute_solid_harmonics_2p(dist_x, dist_y, dist_z, &v_buf_m2l);

    kernels.m2l_translate(&v_buf_m2l, &rx_payload, l_coeff_ptr,
        &m2l_offsets, &m2l_source_indices, &m2l_v_indices, &m2l_sign_rr,
        &m2l_sign_ri, &m2l_sign_ir, &m2l_sign_ii);

    check_m2l_completion();
}


fn process_l2l_local(extra_data: u32) void {
    if (m2l_phase_done == 0) {
        l2l_msg_pending = 1;
        l2l_pending_extra = extra_data;
        const mem_rx_payload_dsd = @get_dsd(mem1d_dsd, .{ .tensor_access = |i|{cons.C_BUF_SIZE} -> rx_payload[i] });
        const mem_l2l_pending_dsd = @get_dsd(mem1d_dsd, .{ .tensor_access = |i|{cons.C_BUF_SIZE} -> l2l_pending_payload[i] });
        @fmovs(mem_l2l_pending_dsd, mem_rx_payload_dsd);
    } else {
        execute_l2l_math(extra_data, &rx_payload);
    }
}

fn execute_l2l_math(extra_data: u32, payload_ptr: *[cons.C_BUF_SIZE]f32) void {
    const level: u16 = @as(u16, extra_data >> 8);
    const child_idx: u32 = extra_data & 0xFF;

    var l_coeff_ptr: *[cons.C_BUF_SIZE]f32 = &l_coeff_buf_lvl4;
    if (level == 3) { l_coeff_ptr = &l_coeff_buf_lvl3; }
    else if (level == 4) { l_coeff_ptr = &l_coeff_buf_lvl4; }
    else { return; }

    var t_vec = @zeros([3]f32);
    if (level == 3) { geom.get_translation_vector(child_idx, 3, &t_vec); }
    else if (level == 4) { geom.get_translation_vector(child_idx, 4, &t_vec); }

    const dx = -t_vec[0];
    const dy = -t_vec[1];
    const dz = -t_vec[2];

    kernels.compute_solid_harmonics(dx, dy, dz, &v_buf);

    kernels.l2l_translate(&v_buf, payload_ptr, l_coeff_ptr,
            &l2l_offsets, &l2l_source_indices, &l2l_v_indices, 
            &l2l_sign_rr, &l2l_sign_ri, &l2l_sign_ir, &l2l_sign_ii);

    if (level < cons.TREE_H) {
        trigger_l2l_send(level); 
    } else {
        start_l2p_phase(); 
    }
}


fn process_p2p_local(extra_data: u32) void {
    const remote_count: u16 = @as(u16, extra_data & 0xFFF);
    
    const local_count: u16 = @as(u16, bodies[1]);
    const offset: u16 = 2;
    
    for (@range(u16, local_count)) |i| {
        const i_b: u16 = offset + i * 4;
        const tx: f32 = @bitcast(f32, bodies[i_b]);
        const ty: f32 = @bitcast(f32, bodies[i_b + 1]);
        const tz: f32 = @bitcast(f32, bodies[i_b + 2]);
        
        var fx: f32 = 0.0;
        var fy: f32 = 0.0;
        var fz: f32 = 0.0;
        var pot: f32 = 0.0;
        
        kernels.evaluate_p2p(tx, ty, tz, &p2p_rx_payload, remote_count, &fx, &fy, &fz, &pot);
        
        // Per ora teniamo += poi vediamo quando si fa pipelining p2p

        const f_idx: u16 = i * 4;
        forces_buf[f_idx]     += fx;
        forces_buf[f_idx + 1] += fy;
        forces_buf[f_idx + 2] += fz;
        forces_buf[f_idx + 3] += pot;
    }
    
    if (expected_rx_p2p[0] > 0) expected_rx_p2p[0] -= 1;
    
    check_completion();
}


// --- M2L SENDER ---
fn start_m2l_phase() void {

    simprint.fmt("({d},{d})STARTM2L", .{pe_x, pe_y});

    for (@range(u16, cons.C_BUF_SIZE)) |i| {
        l_coeff_buf_lvl2[i] = 0.0;
        l_coeff_buf_lvl3[i] = 0.0;
        l_coeff_buf_lvl4[i] = 0.0;
    }

    current_m2l_level = 2;
    send_indices[0] = 0; send_indices[1] = 0; send_indices[2] = 0;
    m2l_tx_done = 0;

    if (get_num_entries(0) > 0 or get_num_entries(1) > 0 or get_num_entries(2) > 0) {
        @activate(cons.m2l_send_task_id);
    } else {
        m2l_tx_done = 1;
        check_m2l_completion();
    }
}

task m2l_send_task() void {
    const chunk_size: u16 = 5;
    var dispatched: u16 = 0;

    while (dispatched < chunk_size) {

        if (current_m2l_level > cons.TREE_H) {
            m2l_tx_done = 1;
            check_m2l_completion();
            return;
        }
        
        const lvl_idx = current_m2l_level - 2;

        if (@as(u32, send_indices[lvl_idx]) >= get_num_entries(lvl_idx)) {
            current_m2l_level += 1;
            continue;
        }

        const target_info = get_target_info(lvl_idx, send_indices[lvl_idx]);
        
        const tgt_x: u16 = @as(u16, (target_info >> 23) & 0x1FF);
        const tgt_y: u16 = @as(u16, (target_info >> 14) & 0x1FF);
        const tag: u16   = @as(u16, (target_info >> 3)  & 0x1FF);

        const extra_data = ((@as(u32, current_m2l_level) - 2) << 9) | @as(u32, tag);

        if (current_m2l_level == 2) { 
            const m_coeff_dsd_lvl2 = @get_dsd(mem1d_dsd, .{ .tensor_access = |i|{cons.C_BUF_SIZE} -> m_coeff_buf_lvl2[i] });
            send_packet(tgt_x, tgt_y, cons.MSG_M2L, extra_data, m_coeff_dsd_lvl2); 
        } else if (current_m2l_level == 3) { 
            const m_coeff_dsd_lvl3 = @get_dsd(mem1d_dsd, .{ .tensor_access = |i|{cons.C_BUF_SIZE} -> m_coeff_buf_lvl3[i] });
            send_packet(tgt_x, tgt_y, cons.MSG_M2L, extra_data, m_coeff_dsd_lvl3); 
        } else if (current_m2l_level == 4) { 
            const g_coeff_dsd = @get_dsd(mem1d_dsd, .{ .tensor_access = |i|{cons.C_BUF_SIZE} -> g_coeff_buf[i] });
            send_packet(tgt_x, tgt_y, cons.MSG_M2L, extra_data, g_coeff_dsd); 
        }

        send_indices[lvl_idx] += 1;
        dispatched += 1;
    }

    if (current_m2l_level <= cons.TREE_H) {
        @activate(cons.m2l_send_task_id);
    } else {
        m2l_tx_done = 1;
        check_m2l_completion();
    }
}


fn check_m2l_completion() void {


    simprint.fmt("({d},{d})CheckM2L-{d},{d},{d}", .{pe_x, pe_y, expected_rx_lvl2[0], expected_rx_lvl3[0], expected_rx_lvl4[0]});

    const lvl2_done = (expected_rx_lvl2[0] == 0);
    const lvl3_done = (expected_rx_lvl3[0] == 0);
    const lvl4_done = (expected_rx_lvl4[0] == 0);
    
    if (lvl2_done and lvl3_done and lvl4_done and m2l_tx_done == 1) {
        m2l_phase_done = 1; 
        if (l2l_msg_pending == 1) {
            execute_l2l_math(l2l_pending_extra, &l2l_pending_payload);
            l2l_msg_pending = 0;
        }
        start_l2l_phase(); 
    }
}


// --- L2L SENDER ---
fn start_l2l_phase() void {

    simprint.fmt("({d},{d})STARTL2L", .{pe_x, pe_y});

    if (pe_min_level <= 2) {
        trigger_l2l_send(2); 
    }
}

fn trigger_l2l_send(my_level: u16) void {
    const child_level = my_level + 1;

    const l_coeff_dsd_lvl2 = @get_dsd(mem1d_dsd, .{ .tensor_access = |i|{cons.C_BUF_SIZE} -> l_coeff_buf_lvl2[i] });
    const l_coeff_dsd_lvl3 = @get_dsd(mem1d_dsd, .{ .tensor_access = |i|{cons.C_BUF_SIZE} -> l_coeff_buf_lvl3[i] });

    var my_l_coeff_dsd: mem1d_dsd = l_coeff_dsd_lvl2;
    if (my_level == 2) { my_l_coeff_dsd = l_coeff_dsd_lvl2; }
    else if (my_level == 3) { my_l_coeff_dsd = l_coeff_dsd_lvl3; }
    else { return; }

    for (@range(u32, 8)) |c_idx| {
        const child_morton = geom.get_child_morton(morton_id, child_level, c_idx);
        
        var tgt_x: u16 = 0; var tgt_y: u16 = 0;
        geom.morton_decode(child_morton, &tgt_x, &tgt_y);

        const extra_data = (@as(u32, child_level) << 8) | c_idx;
        send_packet(tgt_x, tgt_y, cons.MSG_L2L, extra_data, my_l_coeff_dsd);
    }
}


// --- L2P EVALUATION ---
fn start_l2p_phase() void {
    const count : u16 = @as(u16, bodies[1]);
    const bodies_offset : u16 = 2;

    for (@range(u16, count)) |b| {
        var i_b : u16 = bodies_offset + b * 4;
        
        var dx : f32 = @bitcast(f32, bodies[i_b])     - center_x;
        var dy : f32 = @bitcast(f32, bodies[i_b + 1]) - center_y;
        var dz : f32 = @bitcast(f32, bodies[i_b + 2]) - center_z;

        var pot: f32 = 0.0;
        var fx: f32 = 0.0; var fy: f32 = 0.0; var fz: f32 = 0.0;

        kernels.evaluate_l2p(dx, dy, dz, &l_coeff_buf_lvl4, &pot, &fx, &fy, &fz);

        var f_idx: u16 = b * 4;
        forces_buf[f_idx] += fx;
        forces_buf[f_idx + 1] += fy;
        forces_buf[f_idx + 2] += fz;
        forces_buf[f_idx + 3] += pot;
    }

    l2p_done = 1;
    start_p2p_phase();
}


// --- P2P EVALUATION ---
fn start_p2p_phase() void {

    simprint.fmt("({d},{d})STARTP2P", .{pe_x, pe_y});

    const count: u32 = @as(u32, bodies[1]);

    for (@range(u16, cons.P2P_PAYLOAD_SIZE)) |i| {
        p2p_tx_payload[i] = 0.0;
    }
    
    const offset: u16 = 2;
    for (@range(u16, @as(u16,count))) |i| {
        const i_b: u16 = offset + i * 4;
        const o: u16 = i * 4;
        p2p_tx_payload[o]     = @bitcast(f32, bodies[i_b]);
        p2p_tx_payload[o + 1] = @bitcast(f32, bodies[i_b + 1]);
        p2p_tx_payload[o + 2] = @bitcast(f32, bodies[i_b + 2]);
        p2p_tx_payload[o + 3] = @bitcast(f32, bodies[i_b + 3]);
    }
    
    for (@range(u32, num_p2p_neighbors[0])) |i| {
        const target_info = p2p_agenda[i];
        const tgt_x: u16 = @as(u16, (target_info >> 23) & 0x1FF);
        const tgt_y: u16 = @as(u16, (target_info >> 14) & 0x1FF);
        send_p2p_packet(tgt_x, tgt_y, count);
    }
    
    compute_self_p2p();
    check_completion();
}

fn compute_self_p2p() void {
    const count: u16 = @as(u16, bodies[1]);
    const offset: u16 = 2;
    
    for (@range(u16, count)) |i| {
        const i_b: u16 = offset + i * 4;
        const o: u16 = i * 4;
        p2p_rx_payload[o]     = @bitcast(f32, bodies[i_b]);
        p2p_rx_payload[o + 1] = @bitcast(f32, bodies[i_b + 1]);
        p2p_rx_payload[o + 2] = @bitcast(f32, bodies[i_b + 2]);
        p2p_rx_payload[o + 3] = @bitcast(f32, bodies[i_b + 3]);
    }
    
    for (@range(u16, count)) |i| {
        const i_b: u16 = offset + i * 4;
        const tx: f32 = @bitcast(f32, bodies[i_b]);
        const ty: f32 = @bitcast(f32, bodies[i_b + 1]);
        const tz: f32 = @bitcast(f32, bodies[i_b + 2]);
        
        var fx: f32 = 0.0;
        var fy: f32 = 0.0;
        var fz: f32 = 0.0;
        var pot: f32 = 0.0;
        
        kernels.evaluate_p2p(tx, ty, tz, &p2p_rx_payload, count, &fx, &fy, &fz, &pot);
        
        const f_idx: u16 = i * 4;
        forces_buf[f_idx]     += fx;
        forces_buf[f_idx + 1] += fy;
        forces_buf[f_idx + 2] += fz;
        forces_buf[f_idx + 3] += pot;
    }
}

fn check_completion() void {
    if (fmm_done[0] == 1) return;
    if (l2p_done == 1 and expected_rx_p2p[0] == 0) {
        simprint.fmt("({d},{d})FINESIMULAZIONE!", .{pe_x, pe_y});
        fmm_done[0] = 1;
        sys_mod.unblock_cmd_stream();
    }
}

fn send_p2p_packet(tgt_x: u16, tgt_y: u16, count: u32) void {
    const p2p_tx_payload_dsd = @get_dsd(mem1d_dsd, .{ .tensor_access = |i|{cons.P2P_PAYLOAD_SIZE} -> p2p_tx_payload[i] });
    // Usiamo il nuovo router universale asincrono, che farà tutto da solo!
    send_packet(tgt_x, tgt_y, cons.MSG_P2P, count & cons.MASK_11BIT, p2p_tx_payload_dsd);
}


// --- WORMHOLE RECEPTION TASKS ---
task rx_east() void {
    const header = rx_hdr_e[0];
    const tgt_x = (header >> cons.SHIFT_TGT_X) & cons.MASK_9BIT;
    const tgt_y = (header >> cons.SHIFT_TGT_Y) & cons.MASK_9BIT;

    if (tgt_x == @as(u32, pe_x) and tgt_y == @as(u32, pe_y)) {
        const msg_type = (header >> cons.SHIFT_MSG_TYPE) & cons.MASK_3BIT;
        
        if (rx_fifo_count >= cons.FIFO_DEPTH) { simprint.fmt("({d},{d})RX_FIFO FULL(E)", .{pe_x, pe_y}); }
        rx_fifo_headers[rx_fifo_head] = header;
        const base_idx = rx_fifo_head * cons.MAX_PAYLOAD;

        if (msg_type == @as(u32, cons.MSG_P2P)) {
            var dest_dsd = @get_dsd(mem1d_dsd, .{ .tensor_access = |i|{cons.P2P_PAYLOAD_SIZE} -> rx_fifo_payloads[i] });
            dest_dsd = @set_dsd_base_addr(dest_dsd, @ptrcast([*]f32, &rx_fifo_payloads[base_idx]));
            @fmovs(dest_dsd, rx_p2p_payload_e);
        } else {
            var dest_dsd = @get_dsd(mem1d_dsd, .{ .tensor_access = |i|{cons.C_BUF_SIZE} -> rx_fifo_payloads[i] });
            dest_dsd = @set_dsd_base_addr(dest_dsd, @ptrcast([*]f32, &rx_fifo_payloads[base_idx]));
            @fmovs(dest_dsd, rx_fabin_payload_e);
        }

        rx_fifo_head = (rx_fifo_head + 1) & (cons.FIFO_DEPTH - 1);
        rx_fifo_count += 1;
        @activate(cons.process_fifo_task_id);
    } else {
        forward_packet(header, rx_fabin_payload_e, rx_p2p_payload_e);
    }
    
    const mem_rx_hdr_e = @get_dsd(mem1d_dsd, .{ .tensor_access = |i|{1} -> rx_hdr_e[i] });
    @fmovs(mem_rx_hdr_e, rx_fabin_hdr_e, .{ .async = true, .activate = cons.task_rx_east_id });
}

